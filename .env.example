# ============================================================================
# .env.example
# Copy this file to .env and fill in your own values. Never commit a real
# .env file. The Kaggle credentials below are the ONLY manual input this
# project requires — Kaggle's API mandates a personal auth token for any
# programmatic dataset access; this is a platform-level requirement that no
# client library can bypass, including kagglehub.
# ============================================================================

# Required only for automatic dataset download (scripts/download_dataset.py).
# Get these from https://www.kaggle.com/settings -> API -> Create New Token
KAGGLE_USERNAME=
KAGGLE_KEY=

# Optional overrides (defaults come from config/config.yaml if unset)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO
